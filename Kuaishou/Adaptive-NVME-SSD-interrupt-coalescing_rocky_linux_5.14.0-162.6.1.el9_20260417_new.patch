From 9485f89e829131716c32a110c3f322098c03cb8a Mon Sep 17 00:00:00 2001
From: Jun Zeng <jun1.zeng@intel.com>
Date: Fri, 17 Apr 2026 13:03:18 +0800
Subject: [PATCH] Adaptive NVME SSD interrupt coalescing

This solution is to solve NVME SSD interrupt burst issue:
If SSD iops reach a certain pressure level with expected running queues and
avg queue depth/total pending IOs, enable interrupt coalescing automatically,
otherwise disable it when it has been enabled. Also when there is no I/O for
a while, the interrupt coalescing will be disabled if it has been enabled
previously. This feature is disabled by default, and you can enable it during
runtime through variable under /sys/kernel/nvme/ directory or module parameter.
Also you can control some of the runtime parameters of judgement logic through
variables under the same directory.

Signed-off-by: Jun Zeng <jun1.zeng@intel.com>
Signed-off-by: Liang Fang <liang.a.fang@intel.com>
---
 drivers/nvme/host/pci.c | 437 ++++++++++++++++++++++++++++++++++++++++
 1 file changed, 437 insertions(+)

diff --git a/drivers/nvme/host/pci.c b/drivers/nvme/host/pci.c
index 0562d0fe8401..9ed61b206075 100644
--- a/drivers/nvme/host/pci.c
+++ b/drivers/nvme/host/pci.c
@@ -19,6 +19,7 @@
 #include <linux/mm.h>
 #include <linux/module.h>
 #include <linux/mutex.h>
+#include <linux/notifier.h>
 #include <linux/once.h>
 #include <linux/pci.h>
 #include <linux/suspend.h>
@@ -28,6 +29,7 @@
 #include <linux/io-64-nonatomic-hi-lo.h>
 #include <linux/sed-opal.h>
 #include <linux/pci-p2pdma.h>
+#include <linux/printk.h>
 
 #include "trace.h"
 #include "nvme.h"
@@ -160,6 +162,16 @@ struct nvme_dev {
 	unsigned int nr_poll_queues;
 
 	bool attrs_added;
+	/* related definition for adaptive interrupt coalescing */
+	int is_coalescing;
+	int pressure_cnt; /* continous count for state under pressure */
+	int less_pressure_cnt; /* continous count for state under no pressure */
+	int continous_idle_cnt; /* continous no io cycle count */
+	u64 last_total_io_num;
+	ktime_t last_check_time;
+	struct delayed_work coalesce_work;
+	unsigned long *active_q_bitmap;
+	struct notifier_block coalesce_notifier;
 };
 
 static int io_queue_depth_set(const char *val, const struct kernel_param *kp)
@@ -215,6 +227,8 @@ struct nvme_queue {
 	u32 *dbbuf_sq_ei;
 	u32 *dbbuf_cq_ei;
 	struct completion delete_done;
+	/* to count io number of this queue */
+	atomic64_t io_cnt;
 };
 
 /*
@@ -903,6 +917,343 @@ static blk_status_t nvme_map_metadata(struct nvme_dev *dev, struct request *req,
 	cmnd->rw.metadata = cpu_to_le64(iod->meta_dma);
 	return BLK_STS_OK;
 }
+/*
+ * coalescing interrupt control
+ */
+#define NVME_ADAPTIVE_COALESCING_ENABLE 0x0001
+#define NVME_ADAPTIVE_COALESCING_DISABLE 0x0002
+#define SCAN_INTERVAL_MS 100 /* 100 ms */
+#define PRESSURE_HIGH_THRESHOLD  45000 /* 45k io num, for 100 ms */
+#define HIT_COUNT_BEFORE_CHANGE_DEFAULT 5	/* condition hit count before change */
+#define CHECK_INTERVAL                  0x1FF    /* check interval */
+#define COAL_CHECK_AVG_INFLT_IO_THRESH 32
+#define COAL_CHECK_INFLT_IO_THRESH 256
+#define CONT_IDLE_CHECK_CNT 3000
+static BLOCKING_NOTIFIER_HEAD(nvme_adaptive_coalesce_notifier_list);
+static int disable = 1;
+module_param(disable, uint, 0444);
+MODULE_PARM_DESC(disable,
+	"whether to disable the adaptive interrupt coalescing feature, 1 for disable, 0 for not disable, default is 0.");
+
+static int switch_cnt = 0;
+static int coalesce_value = 0x10a;
+static int high_io_delta = PRESSURE_HIGH_THRESHOLD;
+static int scan_interval = SCAN_INTERVAL_MS;
+static int cont_idle_clear_thrsd = CONT_IDLE_CHECK_CNT;
+static u32 avg_qd_threshold = COAL_CHECK_AVG_INFLT_IO_THRESH;
+static u32 total_inflight_io_threshold = COAL_CHECK_INFLT_IO_THRESH;
+
+static int nvme_set_irq_coalesce(struct nvme_ctrl *ctrl, u32 v)
+{
+	return nvme_set_features(ctrl, NVME_FEAT_IRQ_COALESCE, v, NULL, 0, NULL);
+}
+
+static int nvme_get_irq_coalesce(struct nvme_ctrl *ctrl, u32 *v)
+{
+	return nvme_get_features(ctrl, NVME_FEAT_IRQ_COALESCE, 0, NULL, 0, v);
+}
+
+static bool nvme_check_irq_coalesce_supported(struct nvme_ctrl *ctrl)
+{
+	u32 value;
+	int ret;
+	struct nvme_ns *ns;
+
+	ret = nvme_get_irq_coalesce(ctrl, &value);
+	if (ret != 0) {
+		ns = list_first_entry_or_null(&ctrl->namespaces, struct nvme_ns, list);
+		pr_info("interrupt coalescing not supported by %s.\n",
+				ns ? ns->disk->disk_name : "NULL");
+		return false;
+	}
+	return true;
+}
+
+static ssize_t disable_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", disable);
+}
+
+static ssize_t disable_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int old_v = disable;
+	int ret = kstrtoint(buf, 10, &v);
+
+	if (0 == v || 1 == v) {
+		if (v == old_v) {
+			goto out;
+		}
+		disable = v;
+		if (v) {
+			blocking_notifier_call_chain(&nvme_adaptive_coalesce_notifier_list,
+									 NVME_ADAPTIVE_COALESCING_DISABLE, NULL);
+		}
+		else {
+			blocking_notifier_call_chain(&nvme_adaptive_coalesce_notifier_list,
+									 NVME_ADAPTIVE_COALESCING_ENABLE, NULL);
+		}
+	}
+
+	if (1 == v)
+		switch_cnt = 0;
+out:
+	return ret ?: count;
+}
+
+static ssize_t avg_qd_threshold_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", avg_qd_threshold);
+}
+
+static ssize_t avg_qd_threshold_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int ret = kstrtoint(buf, 10, &v);
+
+	avg_qd_threshold = v;
+
+	return ret ?: count;
+}
+
+static ssize_t switch_cnt_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", switch_cnt);
+}
+
+static ssize_t switch_cnt_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int ret = kstrtoint(buf, 10, &v);
+	if(v >= 0)
+		switch_cnt = v;
+	return ret ?: count;
+}
+
+static ssize_t coalesce_value_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", coalesce_value);
+}
+
+static ssize_t coalesce_value_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int ret = kstrtoint(buf, 10, &v);
+	if(v > 0)
+		coalesce_value = v;
+	return ret ?: count;
+}
+
+static ssize_t total_inflight_io_threshold_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", total_inflight_io_threshold);
+}
+
+static ssize_t total_inflight_io_threshold_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int ret = kstrtoint(buf, 10, &v);
+	if(v > 0)
+		total_inflight_io_threshold = v;
+	return ret ?: count;
+}
+
+static ssize_t high_io_delta_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", high_io_delta);
+}
+
+static ssize_t high_io_delta_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int ret = kstrtoint(buf, 10, &v);
+	if(0<=v)
+		high_io_delta = v;
+	return ret ?: count;
+}
+
+static ssize_t scan_interval_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", scan_interval);
+}
+
+static ssize_t scan_interval_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int ret = kstrtoint(buf, 10, &v);
+	if(0<=v) {
+		scan_interval = v;
+		high_io_delta = PRESSURE_HIGH_THRESHOLD * scan_interval / SCAN_INTERVAL_MS;
+	}
+	return ret ?: count;
+}
+
+static ssize_t cont_idle_clear_thrsd_show(struct kobject *kobj, struct kobj_attribute *attr, char *buf) {
+	return sprintf(buf, "%d\n", cont_idle_clear_thrsd);
+}
+
+static ssize_t cont_idle_clear_thrsd_store(struct kobject *kobj, struct kobj_attribute *attr, const char *buf, size_t count) {
+	int v = 0;
+	int ret = kstrtoint(buf, 10, &v);
+	if(0<=v) {
+		cont_idle_clear_thrsd = v;
+	}
+	return ret ?: count;
+}
+
+static struct kobj_attribute disable_attr = __ATTR(disable, 0644, disable_show, disable_store);
+static struct kobj_attribute avg_qd_threshold_attr = __ATTR(avg_qd_threshold, 0644, avg_qd_threshold_show, avg_qd_threshold_store);
+static struct kobj_attribute switch_cnt_attr = __ATTR(switch_cnt, 0644, switch_cnt_show, switch_cnt_store);
+static struct kobj_attribute coalesce_value_attr = __ATTR(coalesce_value, 0644, coalesce_value_show, coalesce_value_store);
+static struct kobj_attribute total_inflight_io_threshold_attr = __ATTR(total_inflight_io_threshold, 0644, total_inflight_io_threshold_show, total_inflight_io_threshold_store);
+static struct kobj_attribute high_io_delta_attr = __ATTR(high_io_delta, 0644, high_io_delta_show, high_io_delta_store);
+static struct kobj_attribute scan_interval_attr = __ATTR(scan_interval, 0644, scan_interval_show, scan_interval_store);
+static struct kobj_attribute cont_idle_clear_thrsd_attr = __ATTR(cont_idle_clear_thrsd, 0644, cont_idle_clear_thrsd_show, cont_idle_clear_thrsd_store);
+
+static inline void adjust_coalesce(struct nvme_dev *dev)
+{
+	u64 now = ktime_get_ns();
+	u64 time_interval;
+	u64 total_io = 0;
+	u64 io_delta = 0;
+	u64 total_inflight_io = 0;
+	struct nvme_queue *nvmeq;
+	struct nvme_ns *ns;
+	u32 avg_inflight_io = 0;
+	u32 busy_queues = 0;
+	int i;
+
+	if (disable ||
+		((dev->is_coalescing == 1) && (dev->continous_idle_cnt > (cont_idle_clear_thrsd / scan_interval)))) {
+		/* clear the coalescing configuration when disable set or continous idle for cont_idle_clear_thrsd s(3 by default) */
+		dev->pressure_cnt = 0;
+		dev->less_pressure_cnt += HIT_COUNT_BEFORE_CHANGE_DEFAULT;
+		time_interval = 0;
+		io_delta = 0;
+		ns = list_first_entry_or_null(&dev->ctrl.namespaces, struct nvme_ns, list);
+		pr_info("clear coalesce, name:%s, for disable been set or no IO for %d cycle with scan_interval:%d.\n",
+			ns ? ns->disk->disk_name : "NULL", dev->continous_idle_cnt, scan_interval);
+		goto do_check;
+	}
+
+	busy_queues = bitmap_weight(dev->active_q_bitmap, dev->nr_allocated_queues);
+	if (!busy_queues) {
+		dev->last_check_time = now;
+		++ dev->continous_idle_cnt;
+		return;
+	}
+
+	dev->continous_idle_cnt = 0;
+	time_interval = ktime_to_ns(ktime_sub(now, dev->last_check_time));
+	dev->last_check_time = now;
+
+	/* count avg queue depth of active queues */
+	for_each_set_bit(i, dev->active_q_bitmap, dev->nr_allocated_queues) {
+		nvmeq = &dev->queues[i];
+		/* count inflight IO for each active queue */
+		total_inflight_io += (nvmeq->sq_tail - nvmeq->cq_head + nvmeq->q_depth) %
+							  nvmeq->q_depth;
+	}
+	avg_inflight_io = div_u64(total_inflight_io, busy_queues);
+
+	/* we can not only loop the active queue, because we should caculate the
+	 * io delta with the last_total_io_num. The active queue bitmap just to
+	 * identify the idle cycle quickly. */
+	for (i = dev->nr_allocated_queues - 1; i > 0; i--) {
+		nvmeq = &dev->queues[i];
+		total_io += atomic64_read(&nvmeq->io_cnt);
+	}
+	bitmap_zero(dev->active_q_bitmap, dev->nr_allocated_queues);
+	io_delta = total_io - dev->last_total_io_num;
+	dev->last_total_io_num = total_io;
+
+	/* the delayed work not that accurate, so adjust the threshold
+	 * according to the real interval */
+	if (io_delta * scan_interval * 1000000 > high_io_delta * time_interval &&
+		(avg_inflight_io > avg_qd_threshold ||
+		 busy_queues * avg_inflight_io > total_inflight_io_threshold)) {
+		dev->pressure_cnt ++;
+		dev->less_pressure_cnt = 0;
+	} else {
+		dev->less_pressure_cnt ++;
+		dev->pressure_cnt = 0;
+	}
+
+do_check:
+	if ((dev->is_coalescing == 0) && dev->pressure_cnt > HIT_COUNT_BEFORE_CHANGE_DEFAULT) {
+		 if (!nvme_set_irq_coalesce(&dev->ctrl, coalesce_value)) {
+			 ns = list_first_entry_or_null(&dev->ctrl.namespaces, struct nvme_ns, list);
+			 pr_info("set coalesce, name:%s, with up_cnt:%d, io_delta:"
+					 "%llu, time_interval:%llu ns, total_io_num:%llu, running_queues:%d\n",
+					 ns ? ns->disk->disk_name : "NULL",
+					 dev->pressure_cnt, io_delta,
+					 time_interval, total_io, busy_queues);
+			 dev->is_coalescing = 1;
+			 dev->pressure_cnt = 0;
+			 dev->less_pressure_cnt = 0;
+			 switch_cnt++;
+		 }
+	} else if ((dev->is_coalescing == 1) &&
+			dev->less_pressure_cnt > HIT_COUNT_BEFORE_CHANGE_DEFAULT) {
+		if (!nvme_set_irq_coalesce(&dev->ctrl, 0x100)) {
+			ns = list_first_entry_or_null(&dev->ctrl.namespaces, struct nvme_ns, list);
+			pr_info("clear coalesce, name:%s, with down_cnt:%d, io_delta:"
+					 "%llu, time_interval:%llu ns, total_io_num:%llu, running_queues:%d\n",
+					 ns ? ns->disk->disk_name : "NULL",
+					 dev->less_pressure_cnt, io_delta,
+					 time_interval, total_io, busy_queues);
+			 dev->is_coalescing = 0;
+			 dev->pressure_cnt = 0;
+			 dev->less_pressure_cnt = 0;
+			 switch_cnt++;
+		}
+	}
+}
+
+void nvme_adjust_coalesce_work(struct work_struct *work)
+{
+	struct nvme_dev *dev = container_of(work, struct nvme_dev, coalesce_work.work);
+	int node = dev_to_node(dev->dev);
+	int cpu = cpumask_last(cpumask_of_node(node));
+
+	if (disable && (dev->is_coalescing == 0)) {
+		return;
+	}
+
+	adjust_coalesce(dev);
+	schedule_delayed_work_on(cpu, &dev->coalesce_work, msecs_to_jiffies(scan_interval));
+}
+
+void nvme_mark_queue_active(struct nvme_queue *nvmeq, u16 sq_tail)
+{
+	if (disable)
+		return;
+
+	if (nvmeq->qid == 0) /* ignore admin op */
+		return;
+
+	if ((sq_tail & CHECK_INTERVAL) == 0 &&
+		!test_bit(nvmeq->qid, nvmeq->dev->active_q_bitmap)) {
+		set_bit(nvmeq->qid, nvmeq->dev->active_q_bitmap);
+	}
+}
+
+/* there is no bitmap_zalloc_node for linux-5.10 kernel version, just construct one here */
+unsigned long *bitmap_zalloc_node(unsigned int nbits, gfp_t flags, int node)
+{
+	return kmalloc_array_node(BITS_TO_LONGS(nbits), sizeof(unsigned long),
+			flags | __GFP_ZERO, node);
+}
+
+static int nvme_pci_coalescing_notify(struct notifier_block *nb,
+		unsigned long action, void *data)
+{
+	struct nvme_dev *dev =
+		container_of(nb, struct nvme_dev, coalesce_notifier);
+	int node = dev_to_node(dev->dev);
+	/* schedule the delayed work for each nvme disk on the last CPU of the same node
+	 * which nvme disk belong to.
+	 */
+	int cpu = cpumask_last(cpumask_of_node(node));
+
+	switch (action) {
+	case NVME_ADAPTIVE_COALESCING_ENABLE:
+		if (nvme_check_irq_coalesce_supported(&dev->ctrl))
+			schedule_delayed_work_on(cpu, &dev->coalesce_work,
+									 msecs_to_jiffies(scan_interval));
+		break;
+	case NVME_ADAPTIVE_COALESCING_DISABLE:
+		/* no need to do things now, the coalesce_work will exit automatically */
+		break;
+	}
+	return NOTIFY_OK;
+}
 
 static blk_status_t nvme_prep_rq(struct nvme_dev *dev, struct request *req)
 {
@@ -945,6 +1296,7 @@ static void nvme_submit_cmds(struct nvme_queue *nvmeq, struct request **rqlist)
 		struct request *req = rq_list_pop(rqlist);
 		struct nvme_iod *iod = blk_mq_rq_to_pdu(req);
 
+		nvme_mark_queue_active(nvmeq, nvmeq->sq_tail + 1);
 		nvme_sq_copy_cmd(nvmeq, &iod->cmd);
 	}
 	nvme_write_sq_db(nvmeq, true);
@@ -1022,6 +1374,9 @@ static blk_status_t nvme_queue_rq(struct blk_mq_hw_ctx *hctx,
 	ret = nvme_prep_rq(dev, req);
 	if (unlikely(ret))
 		return ret;
+
+	nvme_mark_queue_active(nvmeq, nvmeq->sq_tail+1);
+
 	spin_lock(&nvmeq->sq_lock);
 	nvme_sq_copy_cmd(nvmeq, &iod->cmd);
 	nvme_write_sq_db(nvmeq, bd->last);
@@ -1103,6 +1458,8 @@ static inline void nvme_handle_cqe(struct nvme_queue *nvmeq,
 		return;
 	}
 
+	atomic64_inc(&nvmeq->io_cnt);
+
 	trace_nvme_sq(req, cqe->sq_head, nvmeq->sq_tail);
 	if (!nvme_try_complete_req(req, cqe->status, cqe->result) &&
 	    !blk_mq_add_to_batch(req, iob, nvme_req(req)->status,
@@ -1607,6 +1964,7 @@ static int nvme_alloc_queue(struct nvme_dev *dev, int qid, int depth)
 	nvmeq->cq_phase = 1;
 	nvmeq->q_db = &dev->dbs[qid * 2 * dev->db_stride];
 	nvmeq->qid = qid;
+	atomic64_set(&nvmeq->io_cnt, 0);
 	dev->ctrl.queue_count++;
 
 	return 0;
@@ -2768,6 +3126,9 @@ static void nvme_pci_free_ctrl(struct nvme_ctrl *ctrl)
 {
 	struct nvme_dev *dev = to_nvme_dev(ctrl);
 
+	blocking_notifier_chain_unregister(
+			&nvme_adaptive_coalesce_notifier_list,
+			&dev->coalesce_notifier);
 	nvme_dbbuf_dma_free(dev);
 	nvme_free_tagset(dev);
 	if (dev->ctrl.admin_q)
@@ -2775,6 +3136,8 @@ static void nvme_pci_free_ctrl(struct nvme_ctrl *ctrl)
 	free_opal_dev(dev->ctrl.opal_dev);
 	mempool_destroy(dev->iod_mempool);
 	put_device(dev->dev);
+	cancel_delayed_work_sync(&dev->coalesce_work);
+	bitmap_free(dev->active_q_bitmap);
 	kfree(dev->queues);
 	kfree(dev);
 }
@@ -3049,6 +3412,14 @@ static void nvme_async_probe(void *data, async_cookie_t cookie)
 
 	flush_work(&dev->ctrl.reset_work);
 	flush_work(&dev->ctrl.scan_work);
+	if (nvme_check_irq_coalesce_supported(&dev->ctrl) &&
+		!disable) {
+		schedule_delayed_work_on(cpumask_last(cpumask_of_node(dev_to_node(dev->dev))),
+			&dev->coalesce_work, msecs_to_jiffies(scan_interval));
+	} else {
+		dev_warn(dev->ctrl.device, "irq coalesce feature not supported or not to enable"
+				" adaptive irq coalesce, with disable = %d\n", disable);
+	}
 	nvme_put_ctrl(&dev->ctrl);
 }
 
@@ -3067,6 +3438,13 @@ static int nvme_probe(struct pci_dev *pdev, const struct pci_device_id *id)
 	if (!dev)
 		return -ENOMEM;
 
+	dev->is_coalescing = 0;
+	dev->pressure_cnt = 0;
+	dev->less_pressure_cnt = 0;
+	dev->continous_idle_cnt = 0;
+	dev->last_total_io_num = 0;
+	dev->last_check_time = ktime_get_ns();
+
 	dev->nr_write_queues = write_queues;
 	dev->nr_poll_queues = poll_queues;
 	dev->nr_allocated_queues = nvme_max_io_queues(dev) + 1;
@@ -3078,6 +3456,10 @@ static int nvme_probe(struct pci_dev *pdev, const struct pci_device_id *id)
 	dev->dev = get_device(&pdev->dev);
 	pci_set_drvdata(pdev, dev);
 
+	dev->coalesce_notifier.notifier_call = nvme_pci_coalescing_notify;
+	blocking_notifier_chain_register(&nvme_adaptive_coalesce_notifier_list,
+									 &dev->coalesce_notifier);
+
 	result = nvme_dev_map(dev);
 	if (result)
 		goto put_pci;
@@ -3123,6 +3505,14 @@ static int nvme_probe(struct pci_dev *pdev, const struct pci_device_id *id)
 	if (result)
 		goto release_mempool;
 
+	dev->active_q_bitmap = bitmap_zalloc_node(dev->nr_allocated_queues, GFP_KERNEL, node);
+	if (!dev->active_q_bitmap) {
+		nvme_uninit_ctrl(&dev->ctrl);
+		result = -ENOMEM;
+		goto release_mempool;
+	}
+	INIT_DELAYED_WORK(&dev->coalesce_work, nvme_adjust_coalesce_work);
+
 	dev_info(dev->ctrl.device, "pci function %s\n", dev_name(&pdev->dev));
 
 	nvme_reset_ctrl(&dev->ctrl);
@@ -3137,6 +3527,9 @@ static int nvme_probe(struct pci_dev *pdev, const struct pci_device_id *id)
  unmap:
 	nvme_dev_unmap(dev);
  put_pci:
+	blocking_notifier_chain_unregister(
+			&nvme_adaptive_coalesce_notifier_list,
+			&dev->coalesce_notifier);
