From f7d39d54869f53ec4d932cc3bf92251864863929 Mon Sep 17 00:00:00 2001
From: Jun Zeng <jun1.zeng@intel.com>
Date: Wed, 22 Apr 2026 10:01:45 +0800
Subject: [PATCH] nvme-pci: enable/disable interrupt coalescing adaptively
 according to workload

This solution is to solve NVME SSD interrupt burst issue:
If SSD iops reach a certain pressure level with expected running queues and
avg queue depth/total pending IOs, enable interrupt coalescing automatically,
otherwise disable it when it has been enabled. This feature is enabled by
default, can be controlled through debugfs variable during runtime.

Co-developed-by: Liang Fang <liang.a.fang@intel.com>
Signed-off-by: Liang Fang <liang.a.fang@intel.com>
Signed-off-by: Jun Zeng <jun1.zeng@intel.com>
---
 drivers/nvme/host/pci.c | 400 ++++++++++++++++++++++++++++++++++++++++
 1 file changed, 400 insertions(+)

diff --git a/drivers/nvme/host/pci.c b/drivers/nvme/host/pci.c
index 689ef4e2fda5..b700262d8104 100644
--- a/drivers/nvme/host/pci.c
+++ b/drivers/nvme/host/pci.c
@@ -10,6 +10,7 @@
 #include <linux/blk-mq.h>
 #include <linux/blk-mq-pci.h>
 #include <linux/blk-integrity.h>
+#include <linux/debugfs.h>
 #include <linux/dmi.h>
 #include <linux/init.h>
 #include <linux/interrupt.h>
@@ -19,15 +20,19 @@
 #include <linux/mm.h>
 #include <linux/module.h>
 #include <linux/mutex.h>
+#include <linux/notifier.h>
 #include <linux/once.h>
+#include <linux/printk.h>
 #include <linux/pci.h>
 #include <linux/suspend.h>
+#include <linux/seq_file.h>
 #include <linux/t10-pi.h>
 #include <linux/types.h>
 #include <linux/io-64-nonatomic-lo-hi.h>
 #include <linux/io-64-nonatomic-hi-lo.h>
 #include <linux/sed-opal.h>
 #include <linux/pci-p2pdma.h>
+#include <linux/uaccess.h>
 
 #include "trace.h"
 #include "nvme.h"
@@ -160,6 +165,16 @@ struct nvme_dev {
 	unsigned int nr_allocated_queues;
 	unsigned int nr_write_queues;
 	unsigned int nr_poll_queues;
+
+	/* adaptive interrupt coalescing support: */
+	u32 in_coalescing;
+	u32 coalesce_set_streak;
+	u32 coalesce_clear_streak;
+	unsigned long *active_q_bitmap;
+	u64 prev_coal_io_count;
+	ktime_t prev_coal_check_time;
+	struct delayed_work coalesce_work;
+	struct notifier_block coalesce_notifier;
 };
 
 static int io_queue_depth_set(const char *val, const struct kernel_param *kp)
@@ -215,6 +230,8 @@ struct nvme_queue {
 	__le32 *dbbuf_sq_ei;
 	__le32 *dbbuf_cq_ei;
 	struct completion delete_done;
+	/* to count io number of this queue */
+	atomic64_t io_cnt;
 };
 
 union nvme_descriptor {
@@ -871,6 +888,302 @@ static blk_status_t nvme_prep_rq(struct nvme_dev *dev, struct request *req)
 	return ret;
 }
 
+/* definition and logic for adaptive interrupt coalescing */
+#define NVME_ADAPTIVE_COALESCING_ENABLE 0x0001
+#define NVME_ADAPTIVE_COALESCING_DISABLE 0x0002
+#define COAL_CHECK_INTERVAL_MS 100
+#define COAL_CHECK_IO_DELTA_THRESH  45000 /* 45k io num, in 100 ms */
+#define COAL_CHECK_STREAK_THRESH 5
+#define COAL_CHECK_AVG_INFLT_IO_THRESH 32
+#define COAL_CHECK_INFLT_IO_THRESH 256
+#define COALESCE_SET_VALUE 0x10a
+#define COALESCE_CLEAR_VALUE 0x0
+
+static BLOCKING_NOTIFIER_HEAD(nvme_adaptive_coalesce_notifier_list);
+
+/* enable adaptive interrupt coalescing by default */
+static u32 adaptive_coalescing_disabled = 0;
+static u32 high_io_delta = COAL_CHECK_IO_DELTA_THRESH;
+static u32 avg_qd_threshold = COAL_CHECK_AVG_INFLT_IO_THRESH;
+static u32 total_inflight_io_threshold = COAL_CHECK_INFLT_IO_THRESH;
+
+static int nvme_set_irq_coalesce(struct nvme_ctrl *ctrl, u32 v)
+{
+	return nvme_set_features(ctrl, NVME_FEAT_IRQ_COALESCE, v, NULL, 0, NULL);
+}
+
+static int nvme_get_irq_coalesce(struct nvme_ctrl *ctrl, u32 *v)
+{
+	return nvme_get_features(ctrl, NVME_FEAT_IRQ_COALESCE, 0, NULL, 0, v);
+}
+
+static bool nvme_check_irq_coalesce_supported(struct nvme_ctrl *ctrl)
+{
+	u32 value;
+	int ret;
+	struct nvme_ns *ns;
+
+	ret = nvme_get_irq_coalesce(ctrl, &value);
+	if (ret) {
+		mutex_lock(&ctrl->namespaces_lock);
+		ns = list_first_entry_or_null(&ctrl->namespaces, struct nvme_ns, list);
+		dev_info(ctrl->device, "interrupt coalescing not supported by %s.\n",
+				 ns ? ns->disk->disk_name : "NULL");
+		mutex_unlock(&ctrl->namespaces_lock);
+		return false;
+	}
+	return true;
+}
+
+static int disable_adaptive_coalescing_show(void *data, u64 *val)
+{
+	*val = adaptive_coalescing_disabled;
+	return 0;
+}
+
+static int disable_adaptive_coalescing_store(void *data, u64 val)
+{
+	u32 v;
+	u32 old_val = adaptive_coalescing_disabled;
+
+	if (val != 0 && val != 1)
+		return -EINVAL;
+
+	v = (u32)val;
+	if (v == old_val)
+		return 0;
+
+	adaptive_coalescing_disabled = v;
+
+	if (v)
+		blocking_notifier_call_chain(&nvme_adaptive_coalesce_notifier_list,
+									 NVME_ADAPTIVE_COALESCING_DISABLE, NULL);
+	else
+		blocking_notifier_call_chain(&nvme_adaptive_coalesce_notifier_list,
+									 NVME_ADAPTIVE_COALESCING_ENABLE, NULL);
+
+	return 0;
+}
+
+DEFINE_DEBUGFS_ATTRIBUTE(disable_adaptive_coalescing_fops,
+						 disable_adaptive_coalescing_show,
+						 disable_adaptive_coalescing_store,
+						 "%llu\n");
+
+static int high_io_delta_show(void *data, u64 *val)
+{
+	*val = high_io_delta;
+	return 0;
+}
+
+static int high_io_delta_store(void *data, u64 val)
+{
+	high_io_delta = (u32)val;
+	return 0;
+}
+
+DEFINE_DEBUGFS_ATTRIBUTE(high_io_delta_fops,
+						 high_io_delta_show, high_io_delta_store, "%llu\n");
+
+static int avg_qd_threshold_show(void *data, u64 *val)
+{
+	*val = avg_qd_threshold;
+	return 0;
+}
+
+static int avg_qd_threshold_store(void *data, u64 val)
+{
+	avg_qd_threshold = (u32)val;
+	return 0;
+}
+
+DEFINE_DEBUGFS_ATTRIBUTE(avg_qd_threshold_fops,
+						 avg_qd_threshold_show, avg_qd_threshold_store, "%llu\n");
+
+static int total_inflight_io_threshold_show(void *data, u64 *val)
+{
+	*val = total_inflight_io_threshold;
+	return 0;
+}
+
+static int total_inflight_io_threshold_store(void *data, u64 val)
+{
+	total_inflight_io_threshold = (u32)val;
+	return 0;
+}
+
+DEFINE_DEBUGFS_ATTRIBUTE(total_inflight_io_threshold_fops,
+						 total_inflight_io_threshold_show,
+						 total_inflight_io_threshold_store, "%llu\n");
+
+static inline void adjust_coalesce(struct nvme_dev *dev)
+{
+	u64 now = ktime_get_ns();
+	u64 time_interval;
+	u64 current_total_io = 0;
+	u64 io_delta = 0;
+	u64 total_inflight_io = 0;
+	struct nvme_queue *nvmeq;
+	struct nvme_ns *ns;
+	u32 avg_inflight_io = 0;
+	u32 busy_queues = 0;
+	int i;
+
+	if (adaptive_coalescing_disabled) {
+		/* clear the coalescing configuration when disable set */
+		dev->coalesce_set_streak = 0;
+		dev->coalesce_clear_streak += COAL_CHECK_STREAK_THRESH;
+		mutex_lock(&dev->ctrl.namespaces_lock);
+		ns = list_first_entry_or_null(&dev->ctrl.namespaces, struct nvme_ns, list);
+		dev_info(dev->ctrl.device, "clear coalesce, name:%s, for disable been set.\n",
+			ns ? ns->disk->disk_name : "NULL");
+		mutex_unlock(&dev->ctrl.namespaces_lock);
+		goto do_check;
+	}
+
+	busy_queues = bitmap_weight(dev->active_q_bitmap, dev->nr_allocated_queues);
+	if (!busy_queues) {
+		dev->prev_coal_check_time = now;
+		return;
+	}
+
+	time_interval = ktime_to_ns(ktime_sub(now, dev->prev_coal_check_time));
+	dev->prev_coal_check_time = now;
+
+	/* count avg queue depth of active queues */
+	for_each_set_bit(i, dev->active_q_bitmap, dev->nr_allocated_queues) {
+		nvmeq = &dev->queues[i];
+		/* count inflight IO for each active queue */
+		total_inflight_io += (nvmeq->sq_tail - nvmeq->cq_head + nvmeq->q_depth) %
+							  nvmeq->q_depth;
+	}
+	avg_inflight_io = div_u64(total_inflight_io, busy_queues);
+
+	/*
+	 * we can not only loop the active queue, because we should calculate the
+	 * io delta with the prev_coal_io_count. The active queue bitmap just to
+	 * identify the idle cycle quickly.
+	 */
+	for (i = dev->nr_allocated_queues - 1; i > 0; i--) {
+		nvmeq = &dev->queues[i];
+		current_total_io += atomic64_read(&nvmeq->io_cnt);
+	}
+	bitmap_zero(dev->active_q_bitmap, dev->nr_allocated_queues);
+	io_delta = current_total_io - dev->prev_coal_io_count;
+	dev->prev_coal_io_count = current_total_io;
+
+	/*
+	 * The delayed work not that accurate, so adjust the threshold
+	 * according to the real interval. Also check the avg queue depth of active
+	 * queues to identify the case when multiple queues running with small queue
+	 * depth, e.g., bs=4k, job=8, qd=16/32, in which the IOPS can reach threshold
+	 * but it's latency senstive in fact.
+	 */
+	if (io_delta * COAL_CHECK_INTERVAL_MS * 1000000 >
+		high_io_delta * time_interval &&
+		(avg_inflight_io > avg_qd_threshold ||
+		 busy_queues * avg_inflight_io > total_inflight_io_threshold)) {
+		dev->coalesce_set_streak++;
+		dev->coalesce_clear_streak = 0;
+	} else {
+		dev->coalesce_clear_streak++;
+		dev->coalesce_set_streak = 0;
+	}
+
+do_check:
+	if (!dev->in_coalescing && dev->coalesce_set_streak > COAL_CHECK_STREAK_THRESH) {
+		if (!nvme_set_irq_coalesce(&dev->ctrl, COALESCE_SET_VALUE)) {
+			 ns = list_first_entry_or_null(&dev->ctrl.namespaces, struct nvme_ns, list);
+			 pr_info("set coalesce, name:%s, with up_cnt:%d, io_delta:"
+					 "%llu, time_interval:%llu ns, total_io_num:%llu, running_queues:%d\n",
+					 ns ? ns->disk->disk_name : "NULL",
+					 dev->coalesce_set_streak, io_delta,
+					 time_interval, current_total_io, busy_queues);
+			 dev->in_coalescing = 1;
+			 dev->coalesce_set_streak = 0;
+			 dev->coalesce_clear_streak = 0;
+		} else {
+			dev_warn_ratelimited(dev->ctrl.device,
+					 "set irq coalesce with value:%d failed.\n",
+					 COALESCE_SET_VALUE);
+		}
+	} else if (dev->in_coalescing &&
+			dev->coalesce_clear_streak > COAL_CHECK_STREAK_THRESH) {
+		if (!nvme_set_irq_coalesce(&dev->ctrl, COALESCE_CLEAR_VALUE)) {
+			ns = list_first_entry_or_null(&dev->ctrl.namespaces, struct nvme_ns, list);
+			pr_info("clear coalesce, name:%s, with down_cnt:%d, io_delta:"
+					 "%llu, time_interval:%llu ns, total_io_num:%llu, running_queues:%d\n",
+					 ns ? ns->disk->disk_name : "NULL",
+					 dev->coalesce_clear_streak, io_delta,
+					 time_interval, current_total_io, busy_queues);
+			 dev->in_coalescing = 0;
+			 dev->coalesce_set_streak = 0;
+			 dev->coalesce_clear_streak = 0;
+		} else {
+			dev_warn_ratelimited(dev->ctrl.device,
+					 "clear irq coalesce with value:%d failed.\n",
+					 COALESCE_CLEAR_VALUE);
+		}
+	}
+}
+
+static void nvme_adjust_coalesce_work(struct work_struct *work)
+{
+	struct nvme_dev *dev = container_of(work, struct nvme_dev, coalesce_work.work);
+	int node = dev_to_node(dev->dev);
+	/* schedule the delayed work for each nvme disk on the last CPU of the same node
+	 * which nvme disk belong to.
+	 */
+	int cpu = cpumask_last(cpumask_of_node(node));
+
+	if (adaptive_coalescing_disabled && !dev->in_coalescing)
+		return;
+
+	adjust_coalesce(dev);
+	schedule_delayed_work_on(cpu, &dev->coalesce_work,
+							 msecs_to_jiffies(COAL_CHECK_INTERVAL_MS));
+}
+
+static void nvme_mark_queue_active(struct nvme_queue *nvmeq, u16 sq_tail)
+{
+	if (adaptive_coalescing_disabled)
+		return;
+
+	/* ignore admin op */
+	if (nvmeq->qid == 0)
+		return;
+
+	/* no need to check every time, so do it with interval 0x1FF */
+	if ((sq_tail & 0x1FF) == 0 &&
+		!test_bit(nvmeq->qid, nvmeq->dev->active_q_bitmap)) {
+		set_bit(nvmeq->qid, nvmeq->dev->active_q_bitmap);
+	}
+}
+
+static int nvme_pci_coalescing_notify(struct notifier_block *nb,
+		unsigned long action, void *data)
+{
+	struct nvme_dev *dev =
+		container_of(nb, struct nvme_dev, coalesce_notifier);
+	int node = dev_to_node(dev->dev);
+	/* schedule the delayed work for each nvme disk on the last CPU of the same node
+	 * which nvme disk belong to.
+	 */
+	int cpu = cpumask_last(cpumask_of_node(node));
+
+	switch (action) {
+	case NVME_ADAPTIVE_COALESCING_ENABLE:
+		if (nvme_check_irq_coalesce_supported(&dev->ctrl))
+			schedule_delayed_work_on(cpu, &dev->coalesce_work,
+									 msecs_to_jiffies(COAL_CHECK_INTERVAL_MS));
+		break;
+	case NVME_ADAPTIVE_COALESCING_DISABLE:
+		/* no need to do things now, the coalesce_work will exit automatically */
+		break;
+	}
+	return NOTIFY_OK;
+}
+
 /*
  * NOTE: ns is NULL when called on the admin queue.
  */
@@ -896,6 +1209,9 @@ static blk_status_t nvme_queue_rq(struct blk_mq_hw_ctx *hctx,
 	ret = nvme_prep_rq(dev, req);
 	if (unlikely(ret))
 		return ret;
+
+	nvme_mark_queue_active(nvmeq, nvmeq->sq_tail + 1);
+
 	spin_lock(&nvmeq->sq_lock);
 	nvme_sq_copy_cmd(nvmeq, &iod->cmd);
 	nvme_write_sq_db(nvmeq, bd->last);
@@ -911,6 +1227,7 @@ static void nvme_submit_cmds(struct nvme_queue *nvmeq, struct request **rqlist)
 	while ((req = rq_list_pop(rqlist))) {
 		struct nvme_iod *iod = blk_mq_rq_to_pdu(req);
 
+		nvme_mark_queue_active(nvmeq, nvmeq->sq_tail + 1);
 		nvme_sq_copy_cmd(nvmeq, &iod->cmd);
 	}
 	nvme_write_sq_db(nvmeq, true);
@@ -1033,6 +1350,8 @@ static inline void nvme_handle_cqe(struct nvme_queue *nvmeq,
 		return;
 	}
 
+	atomic64_inc(&nvmeq->io_cnt);
+
 	trace_nvme_sq(req, cqe->sq_head, nvmeq->sq_tail);
 	if (!nvme_try_complete_req(req, cqe->status, cqe->result) &&
 	    !blk_mq_add_to_batch(req, iob, nvme_req(req)->status,
@@ -1546,6 +1865,7 @@ static int nvme_alloc_queue(struct nvme_dev *dev, int qid, int depth)
 	nvmeq->cq_phase = 1;
 	nvmeq->q_db = &dev->dbs[qid * 2 * dev->db_stride];
 	nvmeq->qid = qid;
+	atomic64_set(&nvmeq->io_cnt, 0);
 	dev->ctrl.queue_count++;
 
 	return 0;
@@ -2707,8 +3027,13 @@ static void nvme_pci_free_ctrl(struct nvme_ctrl *ctrl)
 {
 	struct nvme_dev *dev = to_nvme_dev(ctrl);
 
+	blocking_notifier_chain_unregister(
+			&nvme_adaptive_coalesce_notifier_list,
+			&dev->coalesce_notifier);
 	nvme_free_tagset(dev);
 	put_device(dev->dev);
+	cancel_delayed_work_sync(&dev->coalesce_work);
+	bitmap_free(dev->active_q_bitmap);
 	kfree(dev->queues);
 	kfree(dev);
 }
@@ -2984,6 +3309,12 @@ static struct nvme_dev *nvme_pci_alloc_dev(struct pci_dev *pdev,
 	INIT_WORK(&dev->ctrl.reset_work, nvme_reset_work);
 	mutex_init(&dev->shutdown_lock);
 
+	dev->in_coalescing = 0;
+	dev->coalesce_set_streak = 0;
+	dev->coalesce_clear_streak = 0;
+	dev->prev_coal_io_count = 0;
+	dev->prev_coal_check_time = ktime_get_ns();
+
 	dev->nr_write_queues = write_queues;
 	dev->nr_poll_queues = poll_queues;
 	dev->nr_allocated_queues = nvme_max_io_queues(dev) + 1;
@@ -2994,6 +3325,10 @@ static struct nvme_dev *nvme_pci_alloc_dev(struct pci_dev *pdev,
 
 	dev->dev = get_device(&pdev->dev);
 
+	dev->coalesce_notifier.notifier_call = nvme_pci_coalescing_notify;
+	blocking_notifier_chain_register(&nvme_adaptive_coalesce_notifier_list,
+									 &dev->coalesce_notifier);
+
 	quirks |= check_vendor_combination_bug(pdev);
 	if (!noacpi &&
 	    !(quirks & NVME_QUIRK_FORCE_NO_SIMPLE_SUSPEND) &&
@@ -3031,9 +3366,19 @@ static struct nvme_dev *nvme_pci_alloc_dev(struct pci_dev *pdev,
 	 * a single integrity segment for the separate metadata pointer.
 	 */
 	dev->ctrl.max_integrity_segments = 1;
+	dev->active_q_bitmap = bitmap_zalloc_node(dev->nr_allocated_queues, GFP_KERNEL, node);
+	if (!dev->active_q_bitmap) {
+		nvme_uninit_ctrl(&dev->ctrl);
+		ret = -ENOMEM;
+		goto out_put_device;
+	}
+	INIT_DELAYED_WORK(&dev->coalesce_work, nvme_adjust_coalesce_work);
 	return dev;
 
 out_put_device:
+	blocking_notifier_chain_unregister(
+			&nvme_adaptive_coalesce_notifier_list,
+			&dev->coalesce_notifier);
 	put_device(dev->dev);
 	kfree(dev->queues);
 out_free_dev:
@@ -3119,6 +3464,17 @@ static int nvme_probe(struct pci_dev *pdev, const struct pci_device_id *id)
 	nvme_start_ctrl(&dev->ctrl);
 	nvme_put_ctrl(&dev->ctrl);
 	flush_work(&dev->ctrl.scan_work);
+	if (nvme_check_irq_coalesce_supported(&dev->ctrl)) {
+		if (!adaptive_coalescing_disabled)
+			/* schedule the delayed work for each nvme disk on the last CPU of
+			 * the same node which nvme disk belong to.
+			 */
+			schedule_delayed_work_on(
+				cpumask_last(cpumask_of_node(dev_to_node(dev->dev))),
+				&dev->coalesce_work, msecs_to_jiffies(COAL_CHECK_INTERVAL_MS));
+	} else {
+		dev_warn(dev->ctrl.device, "irq coalesce feature not supported.\n");
+	}
 	return 0;
 
 out_disable:
@@ -3581,8 +3937,44 @@ static struct pci_driver nvme_driver = {
 	.err_handler	= &nvme_err_handler,
 };
 
+static struct dentry *nvme_dbg_root;
+
 static int __init nvme_init(void)
 {
+	nvme_dbg_root = debugfs_create_dir("nvme", NULL);
+	if (!nvme_dbg_root)
+		return -ENOMEM;
+
+	/* /sys/kernel/debug/nvme/disable_adaptive_interrupt_coalescing */
+	if (!debugfs_create_file("disable_adaptive_interrupt_coalescing",
+							 0644, nvme_dbg_root, NULL,
+							 &disable_adaptive_coalescing_fops)) {
+		pr_err("Failed to create debugfs file: disable_adaptive_interrupt_coalescing\n");
+		goto err_out_dbgfs;
+	}
+
+	/* /sys/kernel/debug/nvme/high_io_delta */
+	if (!debugfs_create_file("high_io_delta", 0644, nvme_dbg_root,
+							 NULL, &high_io_delta_fops)) {
+		pr_err("Failed to create debugfs file: high_io_delta\n");
+		goto err_out_dbgfs;
+	}
+
+	/* /sys/kernel/debug/nvme/avg_qd_threshold */
+	if (!debugfs_create_file("avg_qd_threshold", 0644, nvme_dbg_root,
+							 NULL, &avg_qd_threshold_fops)) {
+		pr_err("Failed to create debugfs file: avg_qd_threshold\n");
+		goto err_out_dbgfs;
+	}
+
+	/* /sys/kernel/debug/nvme/total_inflight_io_threshold */
+	if (!debugfs_create_file("total_inflight_io_threshold", 0644,
+							 nvme_dbg_root, NULL,
+							 &total_inflight_io_threshold_fops)) {
+		pr_err("Failed to create debugfs file: total_inflight_io_threshold\n");
+		goto err_out_dbgfs;
+	}
+
 	BUILD_BUG_ON(sizeof(struct nvme_create_cq) != 64);
 	BUILD_BUG_ON(sizeof(struct nvme_create_sq) != 64);
 	BUILD_BUG_ON(sizeof(struct nvme_delete_queue) != 64);
@@ -3592,12 +3984,20 @@ static int __init nvme_init(void)
 	BUILD_BUG_ON(nvme_pci_npages_prp() > NVME_MAX_NR_ALLOCATIONS);
 
 	return pci_register_driver(&nvme_driver);
+
+err_out_dbgfs:
+	debugfs_remove_recursive(nvme_dbg_root);
+	nvme_dbg_root = NULL;
+	return -ENOMEM;
 }
 
 static void __exit nvme_exit(void)
 {
 	pci_unregister_driver(&nvme_driver);
 	flush_workqueue(nvme_wq);
+
+	debugfs_remove_recursive(nvme_dbg_root);
+	nvme_dbg_root = NULL;
 }
 
 MODULE_AUTHOR("Matthew Wilcox <willy@linux.intel.com>");
