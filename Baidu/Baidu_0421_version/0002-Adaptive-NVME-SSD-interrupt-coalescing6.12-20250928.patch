+/* in 5.10, nvme_queue_rq is inside lock-unlock section, so cannot call nvme_set_irq_coalesce directly, do this in a dedicated thread */
+struct coalesce_op_data {
+	struct nvme_ctrl *ctrl;
+	int coalesce_value;
+};
+
+static struct coalesce_op_data thrd_data = {0};
+#define TASK_AVAILABLE_0 0		// no task is running
+#define TASK_AVAILABLE_1 1		// one thread is preparing the task
+#define TASK_AVAILABLE_2 2		// task has been prepared
+static atomic_t task_available = ATOMIC_INIT(0);
+static DECLARE_COMPLETION(task_completion);
+static struct task_struct *coalesce_thread;
+static bool coal_thrd_running = true;
+
+static int coalesce_thread_function(void *data)
+{
+	u64 start, duration;
+
+	while (coal_thrd_running) {
+		wait_for_completion_interruptible_timeout(&task_completion, msecs_to_jiffies(1000));
+		if (!coal_thrd_running) {
+			break;
+		}
 
+		reinit_completion(&task_completion);
+
+		if (TASK_AVAILABLE_2 == atomic_read(&task_available)) {
+			start = ktime_get_ns();
+			nvme_set_irq_coalesce(thrd_data.ctrl, thrd_data.coalesce_value);
+			duration = ktime_get_ns() - start;
+			pr_debug("nvme_set_irq_coalesce, value=0x%X duration=%llu ns\n", thrd_data.coalesce_value, duration);
+			atomic_set(&task_available, TASK_AVAILABLE_0);
+		}
+	}
+
+	return 0;
+}
+
+static bool schedule_task_set_coalesce(struct nvme_ctrl *ctrl, int coalesce_value)
+{
+	if (TASK_AVAILABLE_0 == atomic_cmpxchg(&task_available, TASK_AVAILABLE_0, TASK_AVAILABLE_1)) {
+		/* successfully get the control */
+		thrd_data.ctrl = ctrl;
+		thrd_data.coalesce_value = coalesce_value;
+		atomic_set(&task_available, TASK_AVAILABLE_2);
+		complete(&task_completion);
+		return true;
+	}
+
+	return false;
+}
+
+static bool record_and_check_busy_queues(struct nvme_queue *nvmeq, struct request *req)
+{
+	struct nvme_dev *dev = nvmeq->dev;
+	int i;
+	int empty_index = -1;
+	int override_index = -1;
+	int busy_queue_num = 1;/* set current queue busy num by default */
+	int updated = 0;
+	ktime_t now = ktime_get();
+	s64 duration_ns;
+	s64 duration_max = 0;
+
+	for (i = 0; i < BUSY_QUEUE_CHECK_NUM; ++i)
+	{
+		if (dev->busy_queues[i].qid == 0xfff) {
+			if (empty_index == -1) {
+				empty_index = i;
+			}
+			continue;
+		}
+		if (dev->busy_queues[i].qid != 0xfff && dev->busy_queues[i].qid == nvmeq->qid) {
+			dev->busy_queues[i].last_time = now;
+			updated = 1;
+			continue;
+		}
+		duration_ns = ktime_to_ns(ktime_sub(now, dev->busy_queues[i].last_time));
+		if ((updated != 1) && duration_ns > duration_max) {
+			duration_max = duration_ns;
+			override_index = i;
+		}
+		if (duration_ns < 1000000000 /* 1000 ms */) {
+			++ busy_queue_num;
+		}
+	}
+
+	if (updated != 1) {
+		if (empty_index != -1) {
+			dev->busy_queues[empty_index].qid = nvmeq->qid;
+			dev->busy_queues[empty_index].last_time = now;
+		} else if (override_index != -1) {
+			dev->busy_queues[override_index].qid = nvmeq->qid;
+			dev->busy_queues[override_index].last_time = now;
+		}
+		else {
+			pr_info("the nvme dev:%s queue to record has qid:%u not found an entry.\n",
+				req->q->disk->disk_name, nvmeq->qid);
+		}
+	}
+
+	if (busy_queue_num > min_running_queues) {
+		return true;
+	}
+
+	return false;
+}
 
 static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req, u16 sq_head, u16 sq_tail)
 {
@@ -999,16 +1166,25 @@ static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req
 		if (duration_ns > 100000000 /* 100 ms */) {
 			if(nvmeq->down_cnt < hit_count_before_change - 1)
 				nvmeq->down_cnt = hit_count_before_change - 1;
-			pr_debug("idle for a while, qid=%hu, duration=%lld\n", nvmeq->qid, duration_ns);
+			pr_debug("idle for a while, name:%s, qid=%hu, duration=%lld, with io size:%u, op:%s, down_cnt:%d, sq_tail:%u, sq_head:%u.\n",
+					req->q->disk->disk_name, nvmeq->qid, duration_ns, blk_rq_bytes(req),
+					rq_data_dir(req) == READ ? "read":"write", nvmeq->down_cnt, sq_tail, sq_head);
 		}
 		nvmeq->last_time = end;
 	}
 
 	while (0 == (sq_tail & CHECK_INTERVAL)) {
 		int inflight = sq_tail-sq_head;
+		int completed = sq_head - nvmeq->last_sq_head;
+
 		if (inflight < 0)
 			inflight += nvmeq->q_depth;
 
+		if (completed < 0)
+			completed += nvmeq->q_depth;
+
+		nvmeq->last_sq_head = sq_head;
+
 		if (0 == sq_tail) {
 			pr_debug("dev=%p, qid=%hu, sq_head=%hu, sq_tail=%hu, inflight=%d, switch_cnt=%d, is_coalescing=%d. up_cnt=%d, down_cnt=%d, online_queue_num=%u, q_depth=%u\n",
 				dev, nvmeq->qid, sq_head, sq_tail, inflight, switch_cnt, dev->is_coalescing, nvmeq->up_cnt, nvmeq->down_cnt, dev->online_queues, nvmeq->q_depth);
@@ -1016,15 +1192,37 @@ static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req
 
 		/* queue full, switch to coalesce interrupt */
 		unsigned int req_size = blk_rq_bytes(req);
+
+		nvmeq->io_cnt += (CHECK_INTERVAL + 1);
+		if (req_size > nvmeq->max_io_size) {
+			nvmeq->max_io_size = req_size;
+		}
+
+		if (req_size < nvmeq->min_io_size) {
+			nvmeq->min_io_size = req_size;
+		}
+
+		if (!nvmeq->ave_io_size) {
+			nvmeq->ave_io_size = req_size;
+		} else {
+			nvmeq->ave_io_size = (nvmeq->ave_io_size + req_size) / 2;
+		}
 		/* lower threshold for big op */
 		int max_threshold = (req_size >= 8192) ? (max_coalesce_threshold>>1) : max_coalesce_threshold;
-		if (dev->is_coalescing != 1 && inflight > max_threshold) {
-			if (rq_data_dir(req) == READ && req_size <32768) { /* no coalesce for write op or huge op*/
+		if (dev->is_coalescing != 1 && ((inflight > max_threshold) || (completed > min_completed_threshold))) {
+			if (req_size <= 32768) { /* no coalescing for op larger than 32768 */
 				if (++nvmeq->up_cnt > hit_count_before_change) {
-					nvme_set_irq_coalesce(ctrl, coalesce_value);
-					dev->is_coalescing = 1;
-					switch_cnt++;
-					nvmeq->last_time = ktime_get();
+					if (record_and_check_busy_queues(nvmeq, req)) {
+						if (schedule_task_set_coalesce(ctrl, coalesce_value)) {
+							pr_info("set coalesce, name:%s, qid=%hu, with io size:%u, op:%s, up_cnt:%d, sq_tail:%u, sq_head:%u, inflight:%u, completed:%u\n",
+							req->q->disk->disk_name, nvmeq->qid, blk_rq_bytes(req),
+							rq_data_dir(req) == READ ? "read":"write", nvmeq->up_cnt, sq_tail, sq_head, inflight, completed);
+							dev->is_coalescing = 1;
+							switch_cnt++;
+							nvmeq->last_time = ktime_get();
+							nvmeq->up_cnt = 0;
+						}
+					}
 				}
 			}
 		} else {
@@ -1035,12 +1233,18 @@ static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req
 		}
 
 		/* queues not so full, close coalesce interrupt */
-		if (dev->is_coalescing == 1 && (inflight < min_coalesce_threshold || rq_data_dir(req) == WRITE)) {
+		if (dev->is_coalescing == 1 && (((inflight < min_coalesce_threshold) && (completed < min_completed_threshold))||
+			(req_size > 32768))) {
 			if (++nvmeq->down_cnt > hit_count_before_change) {
-				nvme_set_irq_coalesce(ctrl, 0);
-				dev->is_coalescing = 0;
-				switch_cnt++;
-				pr_debug("dev=%p, qid=%hu, disable_coalesce.\n", dev, nvmeq->qid);
+				if (schedule_task_set_coalesce(ctrl, 0)) {
+					pr_info("clear coalesce, name:%s, qid=%hu, with io size:%u, op:%s, down_cnt:%d, sq_tail:%u, sq_head:%u, inflight:%u, completed:%u.\n",
+						req->q->disk->disk_name, nvmeq->qid, blk_rq_bytes(req),
+						rq_data_dir(req) == READ ? "read":"write", nvmeq->down_cnt, sq_tail, sq_head, inflight, completed);
+					dev->is_coalescing = 0;
+					switch_cnt++;
+					pr_debug("dev=%p, qid=%hu, disable_coalesce.\n", dev, nvmeq->qid);
+					nvmeq->down_cnt = 0;
+				}
 			}
 		} else {
 			if (0 != nvmeq->down_cnt) {
@@ -1049,6 +1253,14 @@ static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req
 			}
 		}
 
+		if (debug && (0 == (sq_tail & PRINT_INTERVAL))) {
+			pr_info("debug print, name:%s, qid=%hu, is_coalescing:%d, with io size:%u, op:%s, up_cnt:%d, down_cnt:%d, "
+				"sq_tail:%u, sq_head:%u, inflight:%u, completed:%u, io_cnt:%d, max_io_size:%d, ave_io_size:%d, min_io_size:%d.\n",
+				req->q->disk->disk_name, nvmeq->qid, dev->is_coalescing, blk_rq_bytes(req),
+				rq_data_dir(req) == READ ? "read":"write", nvmeq->up_cnt, nvmeq->down_cnt, sq_tail, sq_head, inflight, completed,
+				nvmeq->io_cnt, nvmeq->max_io_size, nvmeq->ave_io_size, nvmeq->min_io_size);
+		}
+
 		break;
 	}
 }
@@ -1095,6 +1307,7 @@ static void nvme_submit_cmds(struct nvme_queue *nvmeq, struct request **rqlist)
 		struct request *req = rq_list_pop(rqlist);
 		struct nvme_iod *iod = blk_mq_rq_to_pdu(req);
 
+		adjust_coalesce(nvmeq, req, nvmeq->sq_head, nvmeq->sq_tail+1);
 		nvme_sq_copy_cmd(nvmeq, &iod->cmd);
 	}
 	nvme_write_sq_db(nvmeq, true);
@@ -1132,8 +1345,6 @@ static void nvme_queue_rqs(struct request **rqlist)
 				continue;
 		}
 
-		adjust_coalesce(nvmeq, req, nvmeq->sq_head, nvmeq->sq_tail+1);
-
 		if (!next || req->mq_hctx != next->mq_hctx) {
 			/* detach rest of list, and submit */
 			req->rq_next = NULL;
@@ -1777,6 +1988,12 @@ static int nvme_alloc_queue(struct nvme_dev *dev, int qid, int depth)
 	nvmeq->qid = qid;
 	nvmeq->up_cnt = 0;
 	nvmeq->down_cnt = 0;
+	nvmeq->sq_head = 0;
+	nvmeq->last_sq_head = 0;
+	nvmeq->io_cnt = 0;
+	nvmeq->max_io_size = 0;
+	nvmeq->min_io_size = 131072;
+	nvmeq->ave_io_size = 0;
 	dev->ctrl.queue_count++;
 
 	return 0;
@@ -3201,6 +3418,7 @@ static struct nvme_dev *nvme_pci_alloc_dev(struct pci_dev *pdev,
 	int node = dev_to_node(&pdev->dev);
 	struct nvme_dev *dev;
 	int ret = -ENOMEM;
+	int i;
 
 	dev = kzalloc_node(sizeof(*dev), GFP_KERNEL, node);
 	if (!dev)
@@ -3209,6 +3427,9 @@ static struct nvme_dev *nvme_pci_alloc_dev(struct pci_dev *pdev,
 	mutex_init(&dev->shutdown_lock);
 
 	dev->is_coalescing = 0;
+	for (i = 0; i < BUSY_QUEUE_CHECK_NUM; ++i) {
