From 4577c10eac3ff6e1d11eb254e6d6bbc30e2d69c4 Mon Sep 17 00:00:00 2001
From: Jun Zeng <jun1.zeng@intel.com>
Date: Mon, 3 Nov 2025 15:48:25 +0800
Subject: [PATCH 3/3] Adaptive NVME SSD interrupt coalescing

check busy queue num before clearing the interrupt coalescing.

Signed-off-by: Jun Zeng <jun1.zeng@intel.com>
---
 drivers/nvme/host/pci.c | 55 ++++++++++++++++++++++++++++++++---------
 1 file changed, 44 insertions(+), 11 deletions(-)

diff --git a/drivers/nvme/host/pci.c b/drivers/nvme/host/pci.c
index 70baf62ac456..46a3902ad366 100644
--- a/drivers/nvme/host/pci.c
+++ b/drivers/nvme/host/pci.c
@@ -1184,6 +1184,32 @@ static bool record_and_check_busy_queues(struct nvme_queue *nvmeq, struct reques
 	return false;
 }
 
+static bool check_busy_queues(struct nvme_queue *nvmeq)
+{
+	struct nvme_dev *dev = nvmeq->dev;
+	int i;
+	int busy_queue_num = 0;
+	ktime_t now = ktime_get();
+	s64 duration_ns;
+
+	for (i = 0; i < BUSY_QUEUE_CHECK_NUM; ++i)
+	{
+		if (dev->busy_queues[i].qid == 0xfff) {
+			continue;
+		}
+		duration_ns = ktime_to_ns(ktime_sub(now, dev->busy_queues[i].last_time));
+		if (duration_ns < 1000000000 /* 1000 ms */) {
+			++ busy_queue_num;
+		}
+	}
+
+	if (busy_queue_num > min_running_queues) {
+		return true;
+	}
+
+	return false;
+}
+
 static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req, u16 sq_head, u16 sq_tail)
 {
 	struct nvme_dev *dev = nvmeq->dev;
@@ -1245,20 +1271,27 @@ static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req
 		}
 		/* lower threshold for big op */
 		int max_threshold = (req_size >= 8192) ? (max_coalesce_threshold>>1) : max_coalesce_threshold;
-		if (dev->is_coalescing != 1 && ((inflight > max_threshold) || (completed > min_completed_threshold))) {
+		if ((inflight > max_threshold) || (completed > min_completed_threshold)) {
 			if (req_size <= 32768) { /* no coalescing for op larger than 32768 */
 				if (++nvmeq->up_cnt > hit_count_before_change) {
-					if (record_and_check_busy_queues(nvmeq, req)) {
-						if (schedule_task_set_coalesce(ctrl, coalesce_value)) {
-							pr_info("set coalesce, name:%s, qid=%hu, with io size:%u, op:%s, up_cnt:%d, sq_tail:%u, sq_head:%u, inflight:%u, completed:%u\n",
-								req->rq_disk->disk_name, nvmeq->qid, blk_rq_bytes(req),
-								rq_data_dir(req) == READ ? "read":"write", nvmeq->up_cnt, sq_tail, sq_head, inflight, completed);
-							dev->is_coalescing = 1;
-							switch_cnt++;
-							nvmeq->last_time = ktime_get();
-							nvmeq->up_cnt = 0;
+					if (dev->is_coalescing != 1) {
+						if (record_and_check_busy_queues(nvmeq, req)) {
+							if (schedule_task_set_coalesce(ctrl, coalesce_value)) {
+								pr_info("set coalesce, name:%s, qid=%hu, with io size:%u, op:%s, up_cnt:%d, sq_tail:%u, "
+									"sq_head:%u, inflight:%u, completed:%u\n",
+									req->rq_disk->disk_name, nvmeq->qid, blk_rq_bytes(req),
+									rq_data_dir(req) == READ ? "read":"write", nvmeq->up_cnt, sq_tail,
+									sq_head, inflight, completed);
+								dev->is_coalescing = 1;
+								switch_cnt++;
+							}
 						}
+					} else {
+						/* just record/update the busy queue info. */
+						(void)record_and_check_busy_queues(nvmeq, req);
 					}
+					nvmeq->last_time = ktime_get();
+					nvmeq->up_cnt = 0;
 				}
 			}
 		} else {
@@ -1271,7 +1304,7 @@ static inline void adjust_coalesce(struct nvme_queue *nvmeq, struct request *req
 		/* queues not so full, close coalesce interrupt */
 		if (dev->is_coalescing == 1 && (((inflight < min_coalesce_threshold) && (completed < min_completed_threshold))||
 			(req_size > 32768))) {
-			if (++nvmeq->down_cnt > hit_count_before_change) {
+			if (++nvmeq->down_cnt > hit_count_before_change && !check_busy_queues(nvmeq)) {
 				if (schedule_task_set_coalesce(ctrl, 0)) {
 					pr_info("clear coalesce, name:%s, qid=%hu, with io size:%u, op:%s, down_cnt:%d, sq_tail:%u, sq_head:%u, inflight:%u, completed:%u.\n",
 						req->rq_disk->disk_name, nvmeq->qid, blk_rq_bytes(req),
